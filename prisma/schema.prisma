// ============================================================
//  Daily Accounting Hub — Prisma Schema (Post-Migration)
//  Matches the Supabase DB after running migration.sql
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organisation {
  id        String   @id @default(cuid())
  name      String
  plan      String   @default("free")
  status    String   @default("active")
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  settings  Settings?
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  password  String
  name      String
  role      String        @default("owner")
  status    String        @default("active")
  orgId     String?
  org       Organisation? @relation(fields: [orgId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

// ── New: Settings per organisation ───────────────────────────
model Settings {
  id                String       @id @default(cuid())
  orgId             String       @unique
  org               Organisation @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoicePrefix     String       @default("INV")
  purchasePrefix    String       @default("PUR")
  defaultTaxRate    Float        @default(13)
  currency          String       @default("NPR")
  currencySymbol    String       @default("रू")
  lowStockThreshold Float        @default(10)
  enableStock       Boolean      @default(true)
  enableLedger      Boolean      @default(true)
  fiscalYearStart   String       @default("07-16")
  orgName           String?
  orgPhone          String?
  orgEmail          String?
  orgAddress        String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Party {
  id             String   @id @default(cuid())
  orgId          String
  name           String
  phone          String   @default("")
  address        String   @default("")
  type           String
  openingBalance Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orgId])
}

model Product {
  id         String   @id @default(cuid())
  orgId      String
  name       String
  category   String
  unit       String
  price      Float
  trackStock Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([orgId])
}

model Account {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  type      String
  balance   Float    @default(0)
  currency  String   @default("NPR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
}

model Invoice {
  id            String        @id @default(cuid())
  orgId         String
  billNumber    String
  partyId       String
  partyName     String
  date          String
  subtotal      Float
  tax           Float         @default(0)
  total         Float
  paidAmount    Float         @default(0)
  dueAmount     Float         @default(0)
  paymentMethod String
  status        String        @default("sent")
  notes         String?
  items         InvoiceItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([orgId, billNumber])
  @@index([orgId])
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  quantity    Float
  rate        Float
  amount      Float
}

model Purchase {
  id             String         @id @default(cuid())
  orgId          String
  purchaseNumber String
  supplierId     String
  supplierName   String
  date           String
  subtotal       Float
  tax            Float          @default(0)
  total          Float
  paidAmount     Float          @default(0)
  dueAmount      Float          @default(0)
  paymentMethod  String
  status         String         @default("received")
  notes          String?
  items          PurchaseItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([orgId, purchaseNumber])
  @@index([orgId])
}

model PurchaseItem {
  id          String   @id @default(cuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId   String
  productName String
  quantity    Float
  rate        Float
  amount      Float
}

model DailyReport {
  id                 String   @id @default(cuid())
  orgId              String
  date               String
  openingCashBalance Float    @default(0)
  bankDeposits       Float    @default(0)
  advancesPaid       Float    @default(0)
  cashReceived       Float    @default(0)
  onlineBankTransfer Float    @default(0)
  creditSales        Float    @default(0)
  totalExpenses      Float    @default(0)
  totalIncome        Float    @default(0)
  closingBalance     Float    @default(0)
  expenses           Json     @default("[]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([orgId, date])
  @@index([orgId])
}

model InventoryItem {
  id           String   @id @default(cuid())
  orgId        String
  productId    String
  productName  String
  openingStock Float    @default(0)
  production   Float    @default(0)
  sales        Float    @default(0)
  closingStock Float    @default(0)
  date         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orgId])
}

model LedgerEntry {
  id          String   @id @default(cuid())
  orgId       String
  partyId     String
  partyName   String
  date        String
  description String
  debit       Float    @default(0)
  credit      Float    @default(0)
  balance     Float    @default(0)
  type        String
  createdAt   DateTime @default(now())

  @@index([orgId])
  @@index([orgId, partyId])
}
