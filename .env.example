# ========================================
# BUSINESS ACCOUNTING SYSTEM
# Environment Configuration
# ========================================

# ========== FRONTEND CONFIGURATION ==========
VITE_API_BASE=http://localhost:3000/api
VITE_APP_NAME=Business Accounting System
VITE_APP_VERSION=1.0.0

# ========== BACKEND CONFIGURATION ==========
NODE_ENV=development
PORT=3000
SERVER_HOST=localhost

# ========== DATABASE CONFIGURATION ==========
# Choose one: mongodb or postgresql
DATABASE_TYPE=mongodb
MONGODB_URI=mongodb://localhost:27017/business-accounting
POSTGRESQL_URL=postgresql://user:password@localhost:5432/business-accounting

# ========== AUTHENTICATION ==========
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# ========== SESSION & SECURITY ==========
SESSION_SECRET=your-session-secret-key
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ========== FILE UPLOAD ==========
MAX_FILE_SIZE=5242880  # 5MB in bytes
UPLOAD_DIR=./uploads

# ========== LOGGING ==========
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# ========== EMAIL (Optional - for notifications) ==========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ========== BUSINESS SETTINGS ==========
CURRENCY=BDT
CURRENCY_SYMBOL=৳
TAX_RATE=15
COMPANY_NAME=Your Business Name
COMPANY_ADDRESS=Your Address
COMPANY_PHONE=Your Phone
COMPANY_EMAIL=Your Email

# ========== FEATURE FLAGS ==========
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_TWO_FACTOR_AUTH=false
ENABLE_AUDIT_LOG=true
ENABLE_DATA_EXPORT=true
